<?xml version="1.0" encoding="utf-8"?>
<manifest xmlns:android="http://schemas.android.com/apk/res/android">

    <uses-permission android:name="android.permission.INTERNET" />

    <!-- Fase D: allarmi esatti (app sveglia/promemoria medico), notifiche
         full-screen, vibrazione e ripianificazione dopo il riavvio. -->
    <uses-permission android:name="android.permission.USE_EXACT_ALARM" />
    <uses-permission android:name="android.permission.POST_NOTIFICATIONS" />
    <uses-permission android:name="android.permission.RECEIVE_BOOT_COMPLETED" />
    <uses-permission android:name="android.permission.USE_FULL_SCREEN_INTENT" />
    <uses-permission android:name="android.permission.VIBRATE" />

    <!-- Fase D.1: suoneria/voce dell'allarme in un foreground service,
         indipendente da notifica e full-screen (HyperOS le muta). -->
    <uses-permission android:name="android.permission.FOREGROUND_SERVICE" />
    <uses-permission android:name="android.permission.FOREGROUND_SERVICE_MEDIA_PLAYBACK" />

    <application
        android:name=".TerapiaApp"
        android:allowBackup="true"
        android:label="@string/app_name"
        android:supportsRtl="true"
        android:theme="@style/Theme.TerapiaNonTeTemo">

        <activity
            android:name=".MainActivity"
            android:exported="true"
            android:theme="@style/Theme.TerapiaNonTeTemo">
            <intent-filter>
                <action android:name="android.intent.action.MAIN" />
                <category android:name="android.intent.category.LAUNCHER" />
            </intent-filter>
        </activity>

        <!-- Allarme a tutto schermo: lanciata SOLO via fullScreenIntent
             della notifica (MAI startActivity dai receiver). -->
        <activity
            android:name=".allarme.AlarmActivity"
            android:excludeFromRecents="true"
            android:exported="false"
            android:launchMode="singleInstance"
            android:showWhenLocked="true"
            android:theme="@style/Theme.TerapiaNonTeTemo"
            android:turnScreenOn="true" />

        <!-- Receiver dell'allarme (target dei PendingIntent di AlarmManager). -->
        <receiver
            android:name=".allarme.AlarmReceiver"
            android:exported="false" />

        <!-- Azioni Fatto / Rimanda dalla notifica di allarme. -->
        <receiver
            android:name=".allarme.AzioneReceiver"
            android:exported="false" />

        <!-- Foreground service che possiede suoneria, vibrazione e voce TTS
             dell'allarme (CONTRACT sez. 13). -->
        <service
            android:name=".allarme.SuonoAllarmeService"
            android:exported="false"
            android:foregroundServiceType="mediaPlayback" />

        <!-- Ripianifica gli allarmi dopo il riavvio del telefono. -->
        <receiver
            android:name=".allarme.BootReceiver"
            android:exported="false">
            <intent-filter>
                <action android:name="android.intent.action.BOOT_COMPLETED" />
            </intent-filter>
        </receiver>

        <!-- FileProvider per la foto della ricetta scattata con la fotocamera
             (file in cacheDir, vedi res/xml/file_paths.xml). Niente permesso CAMERA:
             TakePicture usa l'app fotocamera di sistema. -->
        <provider
            android:name="androidx.core.content.FileProvider"
            android:authorities="${applicationId}.fileprovider"
            android:exported="false"
            android:grantUriPermissions="true">
            <meta-data
                android:name="android.support.FILE_PROVIDER_PATHS"
                android:resource="@xml/file_paths" />
        </provider>

    </application>

</manifest>
